APP_NAME=Boutique API
ENVIRONMENT=local
DEBUG=true
DATABASE_URL=postgresql+asyncpg://boutique:boutique@localhost:5433/boutique
REDIS_URL=redis://localhost:6380/0
DASHBOARD_CACHE_TTL_SECONDS=300

# Set SERVERLESS=true for Lambda so each invocation opens no persistent DB pool.
SERVERLESS=false

# Local JWT authentication. Generate a strong random secret before deploying.
# Auth0 variables are reserved for a future external identity-provider adapter.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
JWT_SECRET=replace-this-before-a-non-local-deployment
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional observability integrations. Keep keys out of version control.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
SENTRY_DSN=

# Kaggle API credentials for the dashboard's one-click Olist import.
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_OLIST_DATASET=olistbr/brazilian-ecommerce
